<?php

/**
 * Fallback when document root CANNOT point to Laravel's public/ folder.
 *
 * 1. Upload full Laravel app to e.g. /home/user/toko-plastik/
 * 2. Copy this file to public_html/index.php
 * 3. Adjust $laravelPublic below to your path
 */

$laravelPublic = __DIR__.'/../toko-plastik/public';

require $laravelPublic.'/index.php';
